[Unit]
Description=GPU Monitor Platform - Scheduler
After=network.target

[Service]
Type=simple
User=%USER%
WorkingDirectory=%INSTALL_DIR%
Environment="PATH=%INSTALL_DIR%/venv/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=%INSTALL_DIR%/venv/bin/python %INSTALL_DIR%/scheduler.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
