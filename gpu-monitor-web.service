[Unit]
Description=GPU Monitor Platform - Web Server
After=network.target gpu-monitor-scheduler.service

[Service]
Type=simple
User=%USER%
WorkingDirectory=%INSTALL_DIR%
Environment="PATH=%INSTALL_DIR%/venv/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=%INSTALL_DIR%/venv/bin/python %INSTALL_DIR%/manage.py runserver 0.0.0.0:8888
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
